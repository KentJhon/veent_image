# ── Immich ────────────────────────────────────────────
UPLOAD_LOCATION=./immich-data
DB_DATA_LOCATION=./immich-db
DB_PASSWORD=postgres
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
IMMICH_VERSION=release

# ── EventSnap App ────────────────────────────────────
APP_DB_PASSWORD=apppassword
AUTH_SECRET=change-me-run-openssl-rand-hex-32
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
IMMICH_ADMIN_API_KEY=your-immich-api-key
IMMICH_RO_USER=sveltekit_ro
IMMICH_RO_PASS=readonly_password
IMMICH_SERVICE_USER_ID=

# ── S3 Storage (optional — originals served from S3 when set) ──
