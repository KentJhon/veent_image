# ── App Database ─────────────────────────────────────
APP_DATABASE_URL=postgresql://app:apppassword@app-database:5432/app

# ── Auth.js ──────────────────────────────────────────
AUTH_SECRET=your-auth-secret-generate-with-openssl-rand-hex-32
AUTH_GOOGLE_ID=your-google-oauth-client-id
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret

# ── Immich Integration ───────────────────────────────
IMMICH_API_URL=http://immich-server:2283/api
IMMICH_API_KEY=your-immich-admin-api-key
IMMICH_ML_URL=http://immich-machine-learning:3003
IMMICH_DB_URL=postgresql://sveltekit_ro:readonly_password@database:5432/immich
IMMICH_SERVICE_USER_ID=your-immich-admin-user-uuid

# ── Watermark Settings ───────────────────────────────
WATERMARK_BRAND_NAME=EventSnap
WATERMARK_OPACITY=0.25
WATERMARK_MAX_PREVIEW_WIDTH=1200
# WATERMARK_CACHE_DIR=/tmp/watermark-cache
